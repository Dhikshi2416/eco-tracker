// Prisma schema for EcoTrack backend
// PostgreSQL database with users, actions, challenges, photos

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  name         String
  password     String
  avatar       String?
  createdAt    DateTime        @default(now())

  actions      Action[]
  challenges   UserChallenge[]
  photos       Photo[]
}

model Action {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  category    String   // transport, food, energy, waste, water
  type        String   // action key, e.g. avoided_car_trip
  description String?
  carbonSaved Float    // kg CO₂
  date        DateTime @default(now())

  photoId     String?
  photo       Photo?   @relation(fields: [photoId], references: [id])

  @@index([userId, date])
}

model Challenge {
  id           String          @id @default(cuid())
  title        String
  description  String
  category     String
  durationDays Int
  targetCount  Int
  carbonGoal   Float

  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())

  participants UserChallenge[]
}

model UserChallenge {
  id          String     @id @default(cuid())
  userId      String
  challengeId String

  user        User       @relation(fields: [userId], references: [id])
  challenge   Challenge  @relation(fields: [challengeId], references: [id])

  progress    Int        @default(0)
  completed   Boolean    @default(false)
  joinedAt    DateTime   @default(now())
  completedAt DateTime?

  @@unique([userId, challengeId], name: "userId_challengeId")
}

model Photo {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  filename  String
  url       String
  size      Int
  mimeType  String
  createdAt DateTime @default(now())

  actions   Action[]
}

